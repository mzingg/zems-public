root = true

[*]
charset = utf-8
end_of_line = lf
tab_width = 2
indent_style = space
indent_size = 2
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.md]
max_line_length = 300

[COMMIT_EDITMSG]
max_line_length = 72 # is also checked in our commit hook

[*.{bat,cmd}]
end_of_line = crlf